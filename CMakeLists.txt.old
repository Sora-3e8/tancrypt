cmake_minimum_required(VERSION 3.16)

project(PKIXCXX VERSION 1.0.0 LANGUAGES CXX)

set(CMAKE_CXX_STANDARD 11)
set(CMAKE_CXX_STANDARD_REQUIRED ON)

# Qt resources handler, uncomment if needed
#set(CMAKE_AUTOMOC ON)
#set(CMAKE_AUTORCC ON)
#set(CMAKE_AUTOUIC ON)

set(SRC_DIR "src")
set(EXECUTABLE_OUTPUT_PATH "bin")

# Build flag for Debug vs Release
# Debug, defines __DEBUG__ for ifdef macro
# Release -O3 optimization
set(CMAKE_CXX_FLAGS_DEBUG "${CMAKE_CXX_FLAGS_DEBUG} -Wall -Wextra -Wpedantic -D__DEBUG__")
set(CMAKE_CXX_FLAGS_RELEASE "${CMAKE_CXX_FLAGS_RELEASE} -O3")

string(TOLOWER "${PROJECT_NAME}" BIN_NAME)
include_directories(include lib)

# Dependency lookup, replace PACKAGE_NAME by your package
find_package(OpenSSL REQUIRED Crypto)

# PkgConfig dependency look up
#find_package(PkgConfig)

# When linking use VAR_NAME as PACKAGE_NAME_LIBS in ${PACKAGE_NAME_LIBS}
#pkg_check_modules(VAR_NAME REQUIRED IMPORTED_TARGET package_name)

# Report missing dependencies to user
if(NOT OpenSSL_FOUND)
  message(FATAL_ERROR "Could not find OpenSSL required components: Crypto")
endif()

# SRC_MAIN are .cpp files, these contain entry points
# SRC_AUX are .cc files, these are auxillary files for headers and libs
file(GLOB_RECURSE SRC_MAIN ${SRC_DIR}/*.cpp)
file(GLOB_RECURSE SRC_AUX ${SRC_DIR}/*.cc)

add_library("${BIN_NAME}" SHARED ${SRC_MAIN} ${SRC_AUX})
set_target_properties("${BIN_NAME}" PROPERTIES
    LIBRARY_OUTPUT_DIRECTORY "bin"
    ARCHIVE_OUTPUT_DIRECTORY "bin"
    RUNTIME_OUTPUT_DIRECTORY "bin")

target_include_directories("${BIN_NAME}" PRIVATE "${CMAKE_CURRENT_SOURCE_DIR}/include")
target_link_libraries("${BIN_NAME}" PRIVATE OpenSSL::Crypto )

